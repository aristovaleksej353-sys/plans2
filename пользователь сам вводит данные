import sqlite3

# Создание и подключение к БД
connection = sqlite3.connect('travel.db')
cursor = connection.cursor()

cursor.execute("PRAGMA foreign_keys = ON")

# Удаление старых таблиц
cursor.execute("DROP TABLE IF EXISTS travel_plans")
cursor.execute("DROP TABLE IF EXISTS countries")
cursor.execute("DROP TABLE IF EXISTS users")

# ТАБЛИЦА ПОЛЬЗОВАТЕЛЕЙ
cursor.execute("""CREATE TABLE users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    age INTEGER NOT NULL
    )""")

# ТАБЛИЦА СТРАН 
cursor.execute("""CREATE TABLE countries (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    users_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    best_season TEXT NOT NULL,
    has_sea TEXT NOT NULL,
    FOREIGN KEY (users_id) REFERENCES users(id)
    )""")

# ТАБЛИЦА ПЛАНОВ ПОЕЗДОК 
cursor.execute("""CREATE TABLE travel_plans (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    users_id INTEGER NOT NULL,
    country_id INTEGER NOT NULL,
    planned_year INTEGER NOT NULL,
    days INTEGER NOT NULL,
    date_returned TEXT,
    FOREIGN KEY (users_id) REFERENCES users(id),
    FOREIGN KEY (country_id) REFERENCES countries(id)
    )""")


# ПОЛЬЗОВАТЕЛЬ ВВОДИТ ДАННЫЕ 

# Ввод пользователя
user_name = input("Введите ваше имя: ")
user_age = int(input("Введите ваш возраст: "))

cursor.execute("""
INSERT INTO users (name, age) VALUES (?, ?)", (user_name, user_age )
""")

# Ввод страны
country_name = input("Название страны: ")
best_season = input("Лучший сезон для поездки (например, май-сентябрь): ")
has_sea = int(input("Есть море? ( да, нет ): "))
cursor.execute("""
INSERT INTO countries (users_id, name, best_season, has_sea) 
 VALUES (?, ?, ?, ?)""")
            
# Ввод плана поездки 
planned_year = int(input("Планируемый год поездки (например, 2025): "))
days = int(input("Количество дней: "))
date_returned = input("Дата возвращения (например, 2025-06-15: ")

cursor.execute("""INSERT INTO travel_plans (users_id, country_id, planned_year, days, date_returned) 
                  VALUES (?, ?, ?, ?, ?)""")


